---
import Base from './Base.astro';
import { noteUrl, STAGE_SYMBOL, STAGE_LABEL } from '../lib/garden';
import type { GardenNote, NoteRef, GardenCollection } from '../lib/garden';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  note: GardenNote;
  backlinks: NoteRef[];
  headings: Heading[];
  prev?: GardenNote | null;
  next?: GardenNote | null;
}

const { note, backlinks, headings, prev, next } = Astro.props;
const { title, stage, tags, date, modified, kind, description, certainty, importance } = note.data;
const isDropCap = kind === 'prose';

const dateStr = date?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const modifiedStr = modified?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Build numbered TOC — h2, h3, h4
interface TocItem { heading: Heading; label: string; }
const tocItems: TocItem[] = [];
let h2Count = 0;
let h3Count = 0;
let h4Count = 0;

for (const h of headings) {
  if (h.depth === 2) {
    h2Count++;
    h3Count = 0;
    h4Count = 0;
    tocItems.push({ heading: h, label: `${h2Count}` });
  } else if (h.depth === 3) {
    h3Count++;
    h4Count = 0;
    tocItems.push({ heading: h, label: `${h2Count}.${h3Count}` });
  } else if (h.depth === 4) {
    h4Count++;
    tocItems.push({ heading: h, label: `${h2Count}.${h3Count}.${h4Count}` });
  }
}
---
<Base title={title} description={description} activeNav={note.collection}>
  <div class="progress-container">
    <div class="progress-bar" id="reading-progress"></div>
  </div>

  <div class="note-layout">

    <!-- Left sidebar: TOC -->
    <aside class="note-sidebar-left" id="note-toc-sidebar">
      {tocItems.length > 0 && (
        <nav class="toc" aria-label="Table of contents">
          <p class="toc-label">Contents</p>
          <ol class="toc-list">
            {tocItems.map(item => (
              <li class={`toc-item depth-${item.heading.depth}`}>
                <span class="toc-num">{item.label}</span>
                <a href={`#${item.heading.slug}`}>{item.heading.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      )}
    </aside>

    <!-- Center: note content -->
    <div class="note-body">
      <header class="note-header">
        {tags.length > 0 && (
          <p class="note-tags">
            {tags.map((tag, i) => (
              <>
                <a href={`/tags/${tag}`} class="note-tag">{tag}</a>
                {i < tags.length - 1 && <span class="note-tag-sep">,</span>}
              </>
            ))}
          </p>
        )}

        <h1 class="note-title">{title}</h1>

        {description && <p class="note-description">{description}</p>}

        <p class="note-meta">
          <span class="note-meta-dates">
            {dateStr}{modifiedStr && modifiedStr !== dateStr && (
              <> (updated {modifiedStr})</>
            )}
          </span>
          <span class="sep">·</span>
          <span class="note-meta-stage" title={`Stage: ${STAGE_LABEL[stage]}`}>
            {STAGE_SYMBOL[stage]} {stage}
          </span>
          {certainty && (
            <>
              <span class="sep">·</span>
              <span class="note-meta-certainty" title="Epistemic certainty">{certainty}</span>
            </>
          )}
        </p>
      </header>

      <div class:list={['prose', isDropCap && 'drop-cap']}>
        <slot />
      </div>

      <!-- Navigation: Prev / Next -->
      {(prev || next) && (
        <nav class="note-nav" aria-label="Note navigation">
          <div class="note-nav-prev">
            {prev && (
              <a href={noteUrl(prev.collection as GardenCollection, prev.slug)}>
                <span class="nav-label">Previous</span>
                <span class="nav-title">{prev.data.title}</span>
              </a>
            )}
          </div>
          <div class="note-nav-next">
            {next && (
              <a href={noteUrl(next.collection as GardenCollection, next.slug)}>
                <span class="nav-label">Next</span>
                <span class="nav-title">{next.data.title}</span>
              </a>
            )}
          </div>
        </nav>
      )}
    </div>

    <!-- Right sidebar: sidenotes + backlinks -->
    <aside class="note-sidebar-right">
      <div class="sidenote-column" id="sidenote-column"></div>

      {backlinks.length > 0 && (
        <div class="backlinks-section">
          <p class="backlinks-label">Linked from</p>
          <ul class="backlinks-list">
            {backlinks.map(link => (
              <li>
                <a href={noteUrl(link.collection as GardenCollection, link.slug)}>
                  {link.title}
                </a>
                <span class="backlinks-collection">{link.collection}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </aside>

  </div>
</Base>

<script>
  import '../scripts/sidenotes.js';

  // Reading progress bar
  const progressBar = document.getElementById('reading-progress');
  if (progressBar) {
    window.addEventListener('scroll', () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      progressBar.style.width = scrolled + "%";
    });
  }
</script>
