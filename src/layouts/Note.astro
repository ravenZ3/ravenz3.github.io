---
import Base from './Base.astro';
import { noteUrl, STAGE_SYMBOL, STAGE_LABEL } from '../lib/garden';
import type { GardenNote, NoteRef, GardenCollection } from '../lib/garden';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  note: GardenNote;
  backlinks: NoteRef[];
  headings: Heading[];
}

const { note, backlinks, headings } = Astro.props;
const { title, stage, tags, date, modified, kind, description, certainty, importance } = note.data;
const isDropCap = kind === 'prose';

const formatDate = (d: Date | undefined) => d?.toISOString().split('T')[0];
const dateStr = formatDate(date);
const modifiedStr = formatDate(modified);

// Build numbered TOC — h2, h3, h4
interface TocItem { heading: Heading; label: string; }
const tocItems: TocItem[] = [];
let h2Count = 0;
let h3Count = 0;
let h4Count = 0;

for (const h of headings) {
  if (h.depth === 2) {
    h2Count++;
    h3Count = 0;
    h4Count = 0;
    tocItems.push({ heading: h, label: `${h2Count}` });
  } else if (h.depth === 3) {
    h3Count++;
    h4Count = 0;
    tocItems.push({ heading: h, label: `${h2Count}.${h3Count}` });
  } else if (h.depth === 4) {
    h4Count++;
    tocItems.push({ heading: h, label: `${h2Count}.${h3Count}.${h4Count}` });
  }
}
---
<Base title={title} description={description} activeNav={note.collection}>
  <div class="sticky-header" id="sticky-header">
    <div class="sticky-title">{title}</div>
    <div class="sticky-section" id="sticky-section"></div>
    <div class="sticky-progress-container">
      <div class="sticky-progress-bar" id="sticky-progress"></div>
    </div>
  </div>

  <div class="note-layout">

    <!-- Left sidebar: TOC -->
    <aside class="note-sidebar-left" id="note-toc-sidebar">
      {tocItems.length > 0 && (
        <nav class="toc" aria-label="Table of contents">
          <p class="toc-label">Contents</p>
          <ol class="toc-list">
            {tocItems.map(item => (
              <li class={`toc-item depth-${item.heading.depth}`}>
                <span class="toc-num">{item.label}</span>
                <a href={`#${item.heading.slug}`}>{item.heading.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      )}
    </aside>

    <!-- Center: note content -->
    <div class="note-body">
      <header class="note-header">
        <p class="note-tags">
          <a href={`/${note.collection}/`} class="note-tag" style="font-style: italic; font-weight: 400;">{note.collection}</a>
        </p>

        <h1 class="note-title">{title}</h1>

        {description && <p class="note-description">{description}</p>}

        <div class="note-meta">
          <span class="note-meta-author">by Ramjan</span>
          <span class="sep">·</span>
          <span class="note-meta-dates">
            {dateStr}{modifiedStr && modifiedStr !== dateStr && (
              <>–{modifiedStr}</>
            )}
          </span>
          <span class="sep">·</span>
          <span class="note-meta-stage" title={`Stage: ${STAGE_LABEL[stage]}`}>
            {stage} {STAGE_SYMBOL[stage]}
          </span>
          {certainty && (
            <>
              <span class="sep">·</span>
              <span class="note-meta-certainty">
                <span class="note-meta-label">⌊certainty:</span> {certainty} {STAGE_SYMBOL[stage]}
              </span>
            </>
          )}
          {importance !== undefined && (
            <>
              <span class="sep">·</span>
              <span class="note-meta-importance">
                <span class="note-meta-label">⌊importance:</span> {importance}
              </span>
            </>
          )}
        </div>
        <div class="note-meta" style="margin-top: 0.35rem; font-size: 0.78rem;">
          <a href="#backlinks" class="note-tag" style="text-decoration: none;">⌊backlinks☗</a>
          <span class="sep">·</span>
          <a href="#similar" class="note-tag" style="text-decoration: none;">⌊similar≈</a>
        </div>
      </header>

      <div class:list={['prose', isDropCap && 'drop-cap']}>
        <slot />
      </div>

      <!-- Similar Links (Gwern style) -->
      {backlinks.length > 0 && (
        <div id="similar" class="similar-links-section">
          <div class="similar-links-heading">Similar Links</div>
          <ul class="similar-links-grid">
            {backlinks.map(link => (
              <li>
                <a href={noteUrl(link.collection as GardenCollection, link.slug)}>
                  {link.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div style="text-align: center; margin: 4rem 0 2rem; font-family: var(--serif); font-size: 0.9rem;">
        <a href={`/${note.collection}/`} style="text-decoration: none; color: var(--muted);">
          ⌊ Return to {note.collection} index ↖
        </a>
      </div>
    </div>

    <!-- Right sidebar: sidenotes -->
    <aside class="note-sidebar-right">
      <div class="sidenote-column" id="sidenote-column"></div>
    </aside>

  </div>
</Base>

<script>
  import '../scripts/sidenotes.js';

  // Sticky header: progress + current section tracking
  const stickyHeader = document.getElementById('sticky-header');
  const progressBar  = document.getElementById('sticky-progress');

  // Progress bar
  if (progressBar) {
    window.addEventListener('scroll', () => {
      const winScroll = document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      progressBar.style.width = ((winScroll / height) * 100) + '%';

      if (winScroll > 200) {
        stickyHeader?.classList.add('visible');
      } else {
        stickyHeader?.classList.remove('visible');
      }
    }, { passive: true });
  }

  // Section tracking: find the last heading above the viewport midpoint on every scroll
  const stickySection = document.getElementById('sticky-section');

  if (stickySection) {
    const headings = Array.from(
      document.querySelectorAll<HTMLElement>('.prose h1, .prose h2, .prose h3')
    );

    function updateSection() {
      const mid = window.scrollY + window.innerHeight * 0.25;
      let active: HTMLElement | null = null;

      for (const h of headings) {
        if (h.offsetTop <= mid) active = h;
        else break;
      }

      if (active) {
        const tag = active.tagName;
        const text = active.textContent ?? '';
        let label = text;

        if (tag === 'H3') {
          const idx = headings.indexOf(active);
          for (let i = idx - 1; i >= 0; i--) {
            if (headings[i].tagName === 'H2') {
              label = (headings[i].textContent ?? '') + ' › ' + text;
              break;
            }
          }
        }

        stickySection.textContent = label;
        stickySection.style.display = 'block';
      } else {
        stickySection.style.display = 'none';
      }
    }

    window.addEventListener('scroll', updateSection, { passive: true });
    updateSection();
  }
</script>
