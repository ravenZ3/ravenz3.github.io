---
import Base from '../layouts/Base.astro';
import { getAllNotes, COLLECTIONS, STAGE_SYMBOL, STAGE_LABEL, noteUrl } from '../lib/garden';
import type { GardenCollection } from '../lib/garden';

const allNotes = await getAllNotes();

// ── Helper to chunk arrays ────────────────────────────────────
function chunk<T>(arr: T[], size: number): T[][] {
  return Array.from({ length: Math.ceil(arr.length / size) }, (v, i) =>
    arr.slice(i * size, i * size + size)
  );
}

// ── Notes for the "Newest" row (can be 3 categories or 3 sub-cols)
// Let's split Newest into 3 columns if it's a huge list, or just one category of 3.
// But the user's screenshot 113 shows "NEWEST", "POPULAR", "NOTABLE".
// Your site has Literary, Perspectives, Reflections.

const newestNotes = [...allNotes]
  .filter(n => n.data.date)
  .sort((a, b) => b.data.date!.getTime() - a.data.date!.getTime())
  .slice(0, 12);

const literary = allNotes.filter(n => n.collection === 'literary').slice(0, 12);
const perspectives = allNotes.filter(n => n.collection === 'perspectives').slice(0, 12);
const reflections = allNotes.filter(n => n.collection === 'reflections').slice(0, 12);

// Grouping into rows of up to 3 categories each
const categories = [
  { title: 'Newest', notes: newestNotes },
  { title: 'Literary', notes: literary },
  { title: 'Perspectives', notes: perspectives },
  { title: 'Reflections', notes: reflections },
];

const categoryRows = chunk(categories, 3);
---
<Base title="ravenZ3" description="A digital garden of notes — prose, perspectives, and reflections by Ramjan Khandelwal.">
  <div class="home-grid-container">

    <!-- Gwern-style site intro -->
    <div class="home-intro">
      <p>
        This is the website of <strong>Ramjan Khandelwal</strong>. I write about AI, robotics, and the messy beauty of programming.
        <span class="intro-label">Navigation:</span> For information about my site’s philosophy & method, see the <a href="/about">About page</a>.
        <span class="intro-label">Features:</span> To use dark-mode (
          <button class="intro-btn" data-theme-set="auto" title="Auto theme">◑ Auto</button> 
          <button class="intro-btn" data-theme-set="light" title="Light theme">☀ Light</button> 
          <button class="intro-btn" data-theme-set="dark" title="Dark theme">🌙 Dark</button>
        ) or search the site (
          <button class="intro-btn search-trigger" id="intro-search-btn" title="Search notes">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="width: 1em; height: 1em; vertical-align: -0.15em; fill: none; stroke: currentColor; stroke-width: 2;">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65" stroke-linecap="round"/>
            </svg>
          </button>
        ), use the floating toggle bar on the right side.
      </p>
    </div>



    {categoryRows.map((row, rowIdx) => (
      <>
        <div class="category-row">
          {row.map(cat => (
            <section class="category-col">
              <h2 class="category-title">{cat.title}</h2>
              <ul class="category-list">
                {cat.notes.map(note => (
                  <li>
                    <span class="category-icon">✦</span>
                    <a href={noteUrl(note.collection, note.slug)}>{note.data.title}</a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
          {/* Fill empty spots if less than 3 cats in row */}
          {row.length < 3 && [...Array(3 - row.length)].map(() => <div class="category-col empty"></div>)}
        </div>

        {rowIdx < categoryRows.length - 1 && (
          <div class="grid-divider">
            <span>❋</span>
          </div>
        )}
      </>
    ))}

  </div>
</Base>

<style>
/* ── Intro ────────────────────────────────────────────────────── */
.intro-label {
  font-family: var(--sans);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  margin-right: 0.2rem;
}

/* ── Container ────────────────────────────────────────────────── */
.home-grid-container {
  max-width: 960px;
  margin: 0 auto;
  padding: 0.5rem 2.5rem 4rem;
  width: 100%;
}


/* ── Intro ─────────────────────────────────────────────────────── */
.home-intro {
  font-family: var(--serif);
  font-size: 1rem;
  line-height: 1.7;
  max-width: 800px;
  margin: 0 auto 2rem;
  text-align: center;
}
.home-intro strong { font-weight: 600; }
.home-intro a { color: var(--muted); text-decoration: underline; text-decoration-color: var(--border); }
.home-intro a:hover { color: var(--text); }

/* ── Category Row (Grid of Categories) ─────────────────────────── */
.category-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  margin-bottom: 1.5rem;
}

.category-col {
  min-width: 0;
}
.category-col.empty { visibility: hidden; }

.category-title {
  font-family: var(--serif);
  font-size: 1.1rem;
  font-weight: 700;
  font-variant: small-caps;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  border-bottom: 1px dotted var(--border);
  padding-bottom: 0.3rem;
  margin-bottom: 1rem;
  color: var(--text);
  text-align: center;
}

.category-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.category-list li {
  display: flex;
  align-items: baseline;
  gap: 0.4rem;
  padding: 0.15rem 0;
  line-height: 1.3;
}

.category-icon {
  font-size: 0.7rem;
  flex-shrink: 0;
  color: var(--muted);
  font-family: var(--sans);
}

.category-list a {
  font-family: var(--serif);
  font-size: 0.95rem;
  color: var(--text);
  text-decoration: underline;
  text-decoration-color: var(--border);
  text-underline-offset: 3px;
  text-decoration-thickness: 1px;
}
.category-list a:hover {
  text-decoration-color: var(--muted);
}

/* ── Divider ───────────────────────────────────────────────────── */
.grid-divider {
  text-align: center;
  padding: 1.5rem 0;
  color: var(--border);
  font-size: 1.4rem;
  line-height: 1;
}

/* ── Responsive ────────────────────────────────────────────────── */
@media (max-width: 1000px) {
  .category-row {
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
}

@media (max-width: 600px) {
  .category-row {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .home-grid-container {
    padding: 1.5rem 1rem;
  }
}
</style>
