---
import Base from '../layouts/Base.astro';
import { getAllNotes, COLLECTIONS, STAGE_SYMBOL, STAGE_LABEL, noteUrl } from '../lib/garden';
import type { GardenCollection } from '../lib/garden';

const allNotes = await getAllNotes();

// ── Helper to chunk arrays ────────────────────────────────────
function chunk<T>(arr: T[], size: number): T[][] {
  return Array.from({ length: Math.ceil(arr.length / size) }, (v, i) =>
    arr.slice(i * size, i * size + size)
  );
}

// ── Notes for the "Newest" row (can be 3 categories or 3 sub-cols)
// Let's split Newest into 3 columns if it's a huge list, or just one category of 3.
// But the user's screenshot 113 shows "NEWEST", "POPULAR", "NOTABLE".
// Your site has Literary, Perspectives, Reflections.

const PREVIEW = 3;

const newestNotes = [...allNotes]
  .filter(n => n.data.date)
  .sort((a, b) => b.data.date!.getTime() - a.data.date!.getTime());

const literary = allNotes.filter(n => n.collection === 'literary').sort((a,b) => { const o={evergreen:0,budding:1,seedling:2}; return o[a.data.stage]-o[b.data.stage]; });
const perspectives = allNotes.filter(n => n.collection === 'perspectives').sort((a,b) => { const o={evergreen:0,budding:1,seedling:2}; return o[a.data.stage]-o[b.data.stage]; });
const reflections = allNotes.filter(n => n.collection === 'reflections').sort((a,b) => { const o={evergreen:0,budding:1,seedling:2}; return o[a.data.stage]-o[b.data.stage]; });

const categories = [
  { title: 'Newest',       href: null,             notes: newestNotes },
  { title: 'Literary',     href: '/literary',      notes: literary },
  { title: 'Perspectives', href: '/perspectives',  notes: perspectives },
  { title: 'Reflections',  href: '/reflections',   notes: reflections },
];

const featuredNotes = allNotes
  .filter(n => n.data.stage === 'evergreen')
  .sort((a, b) => {
    if (a.data.date && b.data.date) return b.data.date.getTime() - a.data.date.getTime();
    return 0;
  })
  .slice(0, 3);

const categoryRows = chunk(categories, 3);
---
<Base title="ravenZ3" description="A digital garden of notes — prose, perspectives, and reflections by Ramjan Khandelwal.">
  <div class="home-grid-container">

    <!-- Gwern-style site intro -->
    <div class="home-intro">
      <p>
        This is the website of <strong>Ramjan Khandelwal</strong>. I write about AI, robotics, and the messy beauty of programming.
        <span class="intro-label">Navigation:</span> For information about my site’s philosophy & method, see the <a href="/about">About page</a>.
        <span class="intro-label">Features:</span> To use dark-mode (
          <button class="intro-btn" data-theme-set="auto" title="Auto theme">◑ Auto</button> 
          <button class="intro-btn" data-theme-set="light" title="Light theme">☀ Light</button> 
          <button class="intro-btn" data-theme-set="dark" title="Dark theme">🌙 Dark</button>
        ) or search the site (
          <button class="intro-btn search-trigger" id="intro-search-btn" title="Search notes">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="width: 1em; height: 1em; vertical-align: -0.15em; fill: none; stroke: currentColor; stroke-width: 2;">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65" stroke-linecap="round"/>
            </svg>
          </button>
        ), use the floating toggle bar on the right side.
      </p>
    </div>



    {featuredNotes.length > 0 && (
      <div class="featured-section">
        <span class="featured-label">Featured Articles</span>
        <div class="featured-grid">
          {featuredNotes.map(note => (
            <a href={noteUrl(note.collection, note.slug)} class="featured-item">
              <div class="featured-title">{note.data.title}</div>
              {note.data.description && (
                <p class="featured-desc">{note.data.description}</p>
              )}
              <div class="featured-meta">{note.collection}</div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="stage-filters" id="stage-filters">
      <button class="stage-filter active" data-filter="all">All</button>
      <button class="stage-filter" data-filter="evergreen">● Evergreen</button>
      <button class="stage-filter" data-filter="budding">◑ Budding</button>
      <button class="stage-filter" data-filter="seedling">○ Seedling</button>
    </div>

    {categoryRows.map((row, rowIdx) => (
      <>
        <div class="category-row">
          {row.map(cat => (
            <section class="category-col">
              <h2 class="category-title">
                {cat.href
                  ? <a href={cat.href}>{cat.title}</a>
                  : cat.title}
              </h2>
              <ul class="category-list">
                {cat.notes.map(note => (
                  <li data-stage={note.data.stage ?? 'seedling'}>
                    <span class="category-icon">✦</span>
                    <a href={noteUrl(note.collection, note.slug)}>{note.data.title}</a>
                  </li>
                ))}
              </ul>
              {cat.href && cat.notes.length > PREVIEW && (
                <a href={cat.href} class="category-more">···  {cat.notes.length - PREVIEW} more</a>
              )}
            </section>
          ))}
          {row.length < 3 && [...Array(3 - row.length)].map(() => <div class="category-col empty"></div>)}
        </div>

        {rowIdx < categoryRows.length - 1 && (
          <div class="grid-divider">
            <span>❋</span>
          </div>
        )}
      </>
    ))}

  </div>
</Base>

<style>
/* ── Intro ────────────────────────────────────────────────────── */
.intro-label {
  font-family: var(--sans);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  margin-right: 0.2rem;
}

/* ── Container ────────────────────────────────────────────────── */
.home-grid-container {
  max-width: 960px;
  margin: 0 auto;
  padding: 0.5rem 2.5rem 4rem;
  width: 100%;
}


/* ── Intro ─────────────────────────────────────────────────────── */
.home-intro {
  font-family: var(--serif);
  font-size: 1rem;
  line-height: 1.7;
  max-width: 800px;
  margin: 0 auto 2rem;
  text-align: center;
}
.home-intro strong { font-weight: 400; font-style: italic; }
.home-intro a { color: var(--muted); text-decoration: underline; text-decoration-color: var(--border); }
.home-intro a:hover { color: var(--text); }

/* ── Category Row (Grid of Categories) ─────────────────────────── */
.category-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  margin-bottom: 1.5rem;
}

.category-col {
  min-width: 0;
}
.category-col.empty { visibility: hidden; }

.category-title {
  font-family: var(--serif);
  font-size: 0.95rem;
  font-weight: 600;
  font-variant: small-caps;
  letter-spacing: 0.05em;
  border-bottom: 1px dotted var(--border);
  padding-bottom: 0.35rem;
  margin-bottom: 1rem;
  color: var(--muted);
  text-align: center;
}

.category-title a {
  color: inherit;
  text-decoration: none;
}

.category-title a:hover {
  text-decoration: underline;
  text-decoration-color: var(--border);
  text-underline-offset: 3px;
}

.category-more {
  display: block;
  margin-top: 0.5rem;
  font-family: var(--serif);
  font-style: italic;
  font-size: 0.78rem;
  color: var(--faint);
  text-decoration: none;
  text-align: center;
  letter-spacing: 0.03em;
  transition: color 0.1s;
}

.category-more:hover {
  color: var(--muted);
}

.category-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.category-list li {
  display: flex;
  align-items: baseline;
  gap: 0.4rem;
  padding: 0.15rem 0;
  line-height: 1.3;
}

.category-icon {
  font-size: 0.7rem;
  flex-shrink: 0;
  color: var(--muted);
  font-family: var(--sans);
}

.category-list a {
  font-family: var(--serif);
  font-size: 0.95rem;
  color: var(--text);
  text-decoration: underline;
  text-decoration-color: var(--border);
  text-underline-offset: 3px;
  text-decoration-thickness: 1px;
}
.category-list a:hover {
  text-decoration-color: var(--muted);
}

/* ── Divider ───────────────────────────────────────────────────── */
.grid-divider {
  text-align: center;
  padding: 1.5rem 0;
  color: var(--border);
  font-size: 1.4rem;
  line-height: 1;
}

/* ── Featured section ─────────────────────────────────────────── */
.featured-section {
  margin: 0 0 1.75rem;
  padding: 1rem 0 1.25rem;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.featured-label {
  display: block;
  font-family: var(--sans);
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--faint);
  margin-bottom: 0.9rem;
}

.featured-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 0.9rem 3rem;
}

.featured-item {
  display: block;
  text-decoration: none;
}

.featured-title {
  font-family: var(--serif);
  font-size: 1.05rem;
  font-weight: 400;
  color: var(--text);
  line-height: 1.35;
  margin-bottom: 0.2rem;
  transition: color 0.15s;
}

.featured-item:hover .featured-title {
  text-decoration: underline;
  text-decoration-color: var(--faint);
  text-decoration-thickness: 1px;
  text-underline-offset: 3px;
}

.featured-desc {
  font-family: var(--serif);
  font-size: 0.82rem;
  font-style: italic;
  color: var(--muted);
  line-height: 1.5;
  margin: 0 0 0.25rem;
}

.featured-meta {
  font-family: var(--sans);
  font-size: 0.52rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--faint);
}

/* ── Stage filters ─────────────────────────────────────────────── */
.stage-filters {
  display: flex;
  justify-content: center;
  gap: 0.4rem;
  margin-bottom: 2rem;
}

.stage-filter {
  border: 1px solid var(--border);
  background: transparent;
  color: var(--muted);
  font-family: var(--sans);
  font-size: 0.58rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.2rem 0.65rem;
  cursor: pointer;
  border-radius: 2px;
  transition: all 0.1s;
}

.stage-filter:hover {
  color: var(--text);
  border-color: var(--muted);
}

.stage-filter.active {
  background: var(--surface);
  color: var(--text);
  border-color: var(--muted);
}

/* ── Responsive ────────────────────────────────────────────────── */
@media (max-width: 1000px) {
  .category-row {
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
}

@media (max-width: 600px) {
  .category-row {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .home-grid-container {
    padding: 1.5rem 1rem;
  }
}
</style>

<script>
  const LIMIT = 3;

  function applyFilter(filter: string) {
    document.querySelectorAll<HTMLElement>('.category-list').forEach(list => {
      const items = Array.from(list.querySelectorAll<HTMLElement>('li[data-stage]'));
      if (filter === 'all') {
        items.forEach((li, i) => { li.style.display = i < LIMIT ? '' : 'none'; });
      } else {
        items.forEach(li => { li.style.display = li.dataset.stage === filter ? '' : 'none'; });
      }
    });

    document.querySelectorAll<HTMLElement>('.category-more').forEach(link => {
      link.style.display = filter === 'all' ? '' : 'none';
    });
  }

  applyFilter('all');

  document.querySelectorAll('.stage-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.stage-filter').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyFilter((btn as HTMLElement).dataset.filter!);
    });
  });
</script>
